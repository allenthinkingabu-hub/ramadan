      "from": [
        "ipm-agent",
        "sa-agent",
        "tl-agent"
      ],
      "to": "supervisor",
      "description": "Role agents invoke their supervisors"
    },
    {
      "event": "SupervisorCompleted",
      "from": "supervisor",
      "to": [
        "ipm-agent",
        "sa-agent",
        "tl-agent"
      ],
      "description": "Supervisors return inspection results"
    }
  ],
  "rules": [
    {
      "name": "wave-ordering",
      "description": "Complete all tasks in Wave N before triggering Wave N+1"
    },
    {
      "name": "parallel-fanout",
      "description": "Tasks within same wave can execute in parallel"
    },
    {
      "name": "supervisor-gate",
